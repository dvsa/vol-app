#!/bin/bash

set -euo pipefail

: "${platformEnv:?platformEnv Jenkins parameter is required}"
: "${Region:?Region Jenkins parameter is required}"

PLATFORM_ENV="${platformEnv}"
REGION="${Region}"

SLACK_CHAN="#platform_alerts"
SLACK_FAIL="#FF9FA1"
SLACK_COMPLETED="#36A64F"
BUILD_NUMBER="${BUILD_NUMBER:-$$}"

function slack_send() {
    local channel="$1"
    local color="$2"
    local message="$3"
    echo "[SLACK] Channel: $channel, Color: $color, Message: $message"
}

function reset_service_password() {
    local env="$1"
    echo "Resetting service passwords for OLCSDB in $env..."
    chmod +x vars/resetServicePassword.sh
    ./vars/resetServicePassword.sh "$env"
}

function generate_user_pool_csv() {
    local env="$1"
    local region="$2"
    echo "Generating new user pool CSV for $env ($region)..."
    vol-jenkinsfiles/infra/nonprod/generate_user_pool "$env" "$region"
}

function load_user_pool() {
    local env="$1"
    local region="$2"
    echo "Loading users into user pool for $env ($region)..."
    vol-jenkinsfiles/infra/nonprod/load_user_pool "$env" "$region"
}

trap 'slack_send "$SLACK_CHAN" "$SLACK_FAIL" "The $PLATFORM_ENV data refresh pipeline has failed"; rm -rf "$WORK_DIR"; exit 1' ERR

WORK_DIR=$(mktemp -d)

slack_send "$SLACK_CHAN" "$SLACK_COMPLETED" "Starting ${PLATFORM_ENV} data refresh pipeline"

reset_service_password "$PLATFORM_ENV"

if ! generate_user_pool_csv "$PLATFORM_ENV" "$REGION"; then
    slack_send "$SLACK_CHAN" "$SLACK_FAIL" "GENERATE_NEW_USER_POOL_CSV_PLB FAILED!"
    exit 1
fi

if ! load_user_pool "$PLATFORM_ENV" "$REGION"; then
    slack_send "$SLACK_CHAN" "$SLACK_FAIL" "Load_User_Pool FAILED!"
    exit 1
fi

rm -rf "$WORK_DIR"
slack_send "$SLACK_CHAN" "$SLACK_COMPLETED" "The $PLATFORM_ENV data refresh pipeline has now completed successfully"
echo "Successfully refreshed data!"