#!/usr/bin/groovy
@Library('shdlb_common') _

// Ugh more silly prodsupp to ps hacks
def labelForBranch(String env) {
	switch(env) {
    case "prodsupp":
    	return "ps"
    default:
      return "${env}"
  }
}

environment = labelForBranch(params.platformEnv)
uppercase_environment = "${environment}".toUpperCase()

def proxyhost='proxy.ci.olcs.dev-dvsacloud.uk' 
def proxyport='3128' 
def noproxy='169.254.169.254' 
def userPoolId=''

pipeline {
  agent {
    node {
      label 'master'
    }
  }

  environment {
    s3bucket='devapp-shd-pri-olcsci-build-s3'
    s3BucketPath='cognito'
    assume_role="arn:aws:iam::054614622558:role/OLCS-DEVAPPCI-DEVCI-Cognito_Pool_Admin"
    passphrase="56B03196-BB37-440C-AAD2-E0E2278CCF33"
    slackChan='#env-status'
    slackFail='#FF9FA1'
    slackCompleted='#36A64F'
    default_email="no@emailaddress.com"
  }

  options { 
    timestamps ()
  }

  parameters {
    choice(name: 'platformEnv', choices: ['dev', 'reg', 'da', 'qa', 'demo', 'prodsupp'], description: 'Environment name to deploy the users too?')
    booleanParam(name: 'deleteUsers', defaultValue: true, description: 'Do we want to delete all existing user pool users?')
    choice(name: 'Region', choices: ['eu-west-1', 'eu-west-2'], description: 'Which AWS region is the user pool in?')
  }

  stages {
    stage('Download user file') {
      steps {
        withAWS(region: "${params.Region}") {
          s3Download(file: "users-${environment}.txt", bucket: "${env.s3bucket}", path: "${env.s3BucketPath}/users-${environment}.txt", force: true)
        }
      }
    }

    stage('Assume role') {
      environment {
        HTTP_PROXY="http://${proxyhost}:${proxyport}"
        HTTPS_PROXY="http://${proxyhost}:${proxyport}"
        NO_PROXY="${noproxy}"
      }
      steps {
        script {
          roleAssumptionResponse = sh (
            script: """aws sts assume-role --role-arn ${assume_role} --role-session-name jenkins --external-id ${env.passphrase} --duration-seconds 900 --output text""", returnStdout: true
          ).trim()
          splitOutput                 = roleAssumptionResponse.split("\\s+")
          env.AWS_ACCESS_KEY_ID       = splitOutput[4]
          env.AWS_SESSION_EXPIRY      = splitOutput[5]
          env.AWS_SECRET_ACCESS_KEY   = splitOutput[6]
          env.AWS_SESSION_TOKEN       = splitOutput[7]
        }
	  	}
    }

    stage('Determine user pool ID') {
      environment {
        HTTP_PROXY="http://${proxyhost}:${proxyport}"
        HTTPS_PROXY="http://${proxyhost}:${proxyport}"
        NO_PROXY="${noproxy}"
      }
      steps {
        script {
          userPoolId = sh (
            script: """aws cognito-idp list-user-pools --query 'UserPools[?Name==`DVSA-DEVAPP${uppercase_environment}-COGNITO-USERS`].[Id]' --region ${params.Region} --max-results 10 --output text --no-cli-pager""", returnStdout: true
          ).trim()
        }
	  	}
    }

    stage('Delete users from user pool') {
      when {
        expression { params.deleteUsers == true }
      }
      environment {
        HTTP_PROXY="http://${proxyhost}:${proxyport}"
        HTTPS_PROXY="http://${proxyhost}:${proxyport}"
        NO_PROXY="${noproxy}"
      }
      steps {
        sh """#!/bin/bash

        /usr/local/bin/delete_users_from_user_pool.py "${userPoolId}" "${params.Region}"
        """
	  	}
    }

    stage('Load users into the user pool') {
      environment {
        HTTP_PROXY="http://${proxyhost}:${proxyport}"
        HTTPS_PROXY="http://${proxyhost}:${proxyport}"
        NO_PROXY="${noproxy}"
      }
      
      steps {
        sh """#!/bin/bash

        /usr/local/bin/load_user_pool.py "${userPoolId}" "${params.Region}" "${environment}" "DEV/APP/CI-COG-KNOWN-PASSWORD" ${env.default_email}
        """
      }
    }

  }

  post {
    success {
      slackSend (channel: "${env.slackChan}", color: "${env.slackCompleted}", message: "${environment} User Pool loaded back to default status")
      deleteDir()
    }
    failure {
      slackSend (channel: "${env.slackChan}", color: "${env.slackFail}", message: "${environment} User Pool loaded back to default status failed\nLogs: ${env.BUILD_URL}consoleFull")
    }
    always {
      deleteDir() 
    }
  }
}
