#!/usr/bin/groovy
@Library('shdlb_common') _

// Ugh more silly prodsupp to ps hacks
def labelForBranch(String env) {
	switch(env) {
    case "prodsupp":
    	return "ps"
    default:
      return "${env}"
  }
}

environment = labelForBranch(params.platformEnv)

pipeline {
  agent {
    node {
      label "${params.run_on_node}"
    }
  }

  environment {
    http_proxy="http://proxy.ci.olcs.dev-dvsacloud.uk:3128"
    https_proxy="http://proxy.ci.olcs.dev-dvsacloud.uk:3128"
    no_proxy='127.0.0.1,localhost,169.254.169.254,.olcs.dev-dvsacloud.uk'
    s3bucket='devapp-shd-pri-olcsci-build-s3'
    s3BucketPath='cognito'
    scriptrepo='https://github.com/dvsa/olcs-etl.git'
    scriptrepobranch='main'
    slackChan='#env-status'
    slackFail='#FF9FA1'
    slackCompleted='#36A64F'
  }
  options { 
    timestamps ()
  }

  parameters {
    string(name: 'run_on_node', defaultValue: "dev&&api&&olcs", description: 'Node to run on')
    choice(name: 'platformEnv', choices: ['dev', 'reg', 'da', 'qa', 'demo', 'prodsupp'], description: 'Determines the environment we want to target')
    choice(name: 'Region', choices: ['eu-west-1', 'eu-west-2'], description: 'Which AWS region is the user pool in?')
  }

  stages {

    stage('Checkout olcs-etl repo') {
      steps {
        checkout([ $class: 'GitSCM', branches: [[name: "refs/heads/${env.scriptrepobranch}"]], doGenerateSubmoduleConfigurations: false, extensions: [[$class: 'RelativeTargetDirectory', relativeTargetDir: 'scripts']], submoduleCfg: [], userRemoteConfigs: [[credentialsId: 'd0ccbb28-42ec-42f2-9615-77fb64e93a28', url: "${env.scriptrepo}"]] ])
      }
    }

    stage('Generate user pool CSV') {
      steps { 
        sh """#!/bin/bash
/usr/bin/php ./scripts/utils/recovery/user-pool-export.php --mode=nonprod-users --perrole="2" --mycnf=/home/jenkins/.my.cnf --output=./db_output.csv
        """
      }
    }

    stage('Upload users CSV to S3') {
      steps {
        withAWS(region: "${params.Region}") {
          s3Upload(bucket: "${env.s3bucket}", path: "${env.s3BucketPath}"+"/"+"users-${environment}.txt", file: "db_output.csv")
        }
      }
    }
   
  }

  post {
    success {
      slackSend (channel: "${env.slackChan}", color: "${env.slackCompleted}", message: "${params.platformEnv} User Pool CSV generated")
      deleteDir()
    }
    failure {
      slackSend (channel: "${env.slackChan}", color: "${env.slackFail}", message: "${params.platformEnv} User Pool CSV generation failed\nLogs: ${env.BUILD_URL}consoleFull")
    }
    always {
      deleteDir() 
    }
  }
}
