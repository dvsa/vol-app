<?xml version="1.0"?>
<psalm
  errorLevel="8"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="https://getpsalm.org/schema/config"
  xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
  findUnusedBaselineEntry="true"
  findUnusedCode="false"
>
  <projectFiles>
    <directory name="module"/>
    <!-- In-tree shared libs (symlinked into vendor/olcs/*) are scanned here for symbol
         resolution (app code uses their classes) but excluded from analysis in
         ignoreFiles below — the libs have their own psalm runs (CI lib matrix). Listing
         in BOTH scans them deterministically (avoids a parallel-scan race) without
         reporting their issues. -->
    <directory name="../../lib"/>
    <ignoreFiles>
          <directory name="vendor" />
          <directory name="../../lib" />
        </ignoreFiles>
  </projectFiles>
  <issueHandlers>
    <!-- Laminas\View\Model\ViewModel marked @final but intended to be extended -->
    <InvalidExtendClass>
      <errorLevel type="suppress">
        <directory name="module/Application/src/View/Model/"/>
        <directory name="module/Olcs/src/View/Model/"/>
      </errorLevel>
    </InvalidExtendClass>
  </issueHandlers>
</psalm>
