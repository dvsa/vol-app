        reason: GPL-3.0 licence concern. OLCS is open source under OGL. Tracked in VOL-5968
        expires: 2027-01-15T00:00:00.000Z
        created: 2024-02-28T13:46:27.880Z
  'snyk:lic:composer:behat:transliterator:Artistic-1.0':
    - '*':
        reason: Issue is due to licence
        expires: 2025-12-18T02:01:00.000Z
        created: 2024-02-28T13:46:38.578Z
  'snyk:lic:composer:paragonie:hidden-string:MPL-2.0':
    - '*':
        reason: >-
          MPL-2.0 is a weak copyleft license that only requires modifications to
          the licensed files themselves to remain under MPL-2.0. We consume this
          library as a dependency without modification, so it is compatible with
          this project. Introduced as a transitive dependency of paragonie/halite
          which replaces the abandoned laminas/laminas-crypt package.
        expires: 2099-12-31T00:00:00.000Z
patch: {}
